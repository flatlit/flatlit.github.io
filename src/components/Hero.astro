---
import { Image } from "astro:assets";

type Props = {
  title?: string;
  description?: string;
  image?: ImageMetadata;
};
// TODO consider overlay... but astro interaction as it's background url

const { title, description, image } = Astro.props;
---

<div class="hero bg-base-200">
  <div class="hero-content flex-col lg:flex-row w-full">
    <div class="grow">
      {title && <h1 class="text-5xl font-bold">{title}</h1>}
      {description && <p class="py-6">{description}</p>}
    </div>
    {
      image && (
        <Image
          class="max-w-sm rounded-lg shadow-2xl"
          width={1020}
          height={510}
          src={image}
          alt={title ?? ""}
        />
      )
    }
  </div>
</div>
