---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Layout from "../layouts/GeneralLayout.astro";
import { publishedFilter } from "../utils";

export async function getStaticPaths() {
  // TODO also the series is published
  const items = await getCollection("articles", publishedFilter);
  return items.map((item) => ({
    params: { slug: item.id },
    props: item,
  }));
}
type Props = CollectionEntry<"articles">;
const item = Astro.props;

const series = (
  await getCollection("series", (s) => s.id === item.data.series)
)[0];
const { Content } = await render(item);
---

<Layout {...item.data} heroImage={item.data.heroImage ?? series.data.heroImage}>
  <Content />
</Layout>
