---
import { getCollection } from "astro:content";
import GeneralCardLink from "../../components/GeneralCardLink.astro";
import Layout from "../../layouts/GeneralLayout.astro";
import { publishedFilter, publishedOrder } from "../../utils";

const posts = (await getCollection("posts", publishedFilter)).sort(
  publishedOrder,
);
---

<Layout title="Updates">
  <section class="grid grid-cols-2 gap-16">
    {posts.map((item) => <GeneralCardLink {item} />)}
  </section>
</Layout>
