---
import { getCollection } from "astro:content";
import logoImage from "../assets/logo.png";
import GameCardLink from "../components/GameCardLink.astro";
import GeneralCardLink from "../components/GeneralCardLink.astro";
import Hero from "../components/Hero.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import Layout from "../layouts/Page.astro";
import { publishedFilter, publishedOrder } from "../utils";

const MAX_GAMES = 3;
const MAX_BLOGS = 3;

const games = (
  await getCollection("games", (e) => e.data.publishedDate && e.data.published)
)
  .sort(publishedOrder)
  .slice(0, MAX_GAMES + 1);

const blogs = (await getCollection("posts", publishedFilter))
  .sort(publishedOrder)
  .slice(0, MAX_BLOGS + 1);

// Another good quote from same guy
// “I run because if I didn’t, I’d be sluggish and glum and spend too much time on the couch. I run to breathe the fresh air. I run to explore. I run to escape the ordinary. I run...to savor the trip along the way. Life becomes a little more vibrant, a little more intense. I like that.”
// Dean Karnazes
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <Hero title={SITE_TITLE} description={SITE_DESCRIPTION} image={logoImage} />
  <div class="flex flex-col gap-4 mt-2">
    {blogs.length > 0 && (<h3 class="text-2xl">Updates</h3>
    <section class="flex flex-col lg:flex-row flex-3 w-full gap-16">
      {blogs.map((item) => <GeneralCardLink {item} />)}
    </section>
    <div class="flex flex-rol justify-end">
      <a class="link
      link-primary
      link-hover" href="/posts"> More posts</a>
    </div>)}
    {games.length > 0 && (<h3 class="text-2xl">Games</h3>
    <section class="flex flex-col lg:flex-row flex-3 w-full gap-16">
      {games.map((item) => <GameCardLink {item} />)}
    </section>
    <div class="flex flex-rol justify-end">
      <a class="link
      link-primary
      link-hover" href="/games">More games</a>
    </div>)}
  </div>
</Layout>
