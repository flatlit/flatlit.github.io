---
// This is to render our series/articles at the top level
// ie so series look like they are top level
// I'm debating moving this under back under series to be honest
// as series/taming-godot/article-name isn't really any different

import { type CollectionEntry, getCollection, render } from "astro:content";
import Layout from "../../layouts/MarkdownLayout.astro";
import {
  articleInPublishedSeriesFilter,
  findPublishedSeriesIds,
  findSeriesOfArticle,
  publishedFilter,
} from "../../utils";

export async function getStaticPaths() {
  const publishedSeriesIds = await findPublishedSeriesIds();
  const items = await getCollection(
    "articles",
    (e) =>
      publishedFilter(e) &&
      articleInPublishedSeriesFilter(publishedSeriesIds, e),
  );
  return items.map((item) => ({
    params: { slug: item.id },
    props: item,
  }));
}
type Props = CollectionEntry<"articles">;
const item = Astro.props;

const series = await findSeriesOfArticle(item);
const { Content } = await render(item);
---

<Layout
  {...item.data}
  heroImage={item.data.heroImage ?? series?.data.heroImage}
>
  <Content />
</Layout>
