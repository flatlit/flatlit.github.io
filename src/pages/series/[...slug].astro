---
// This is to render our series/articles at the top level
// ie so series look like they are top level
// I'm debating moving this under back under series to be honest
// as series/taming-godot/article-name isn't really any different

import { type CollectionEntry, getCollection, render } from "astro:content";
import Layout from "../../layouts/MarkdownLayout.astro";
import { publishedFilter } from "../../utils";

export async function getStaticPaths() {
  // TODO also the series is published
  const items = await getCollection("articles", publishedFilter);
  return items.map((item) => ({
    params: { slug: item.id },
    props: item,
  }));
}
type Props = CollectionEntry<"articles">;
const item = Astro.props;

const series = (
  await getCollection("series", (s) => s.id === item.data.series)
)[0];
const { Content } = await render(item);
---

<Layout {...item.data} heroImage={item.data.heroImage ?? series.data.heroImage}>
  <Content />
</Layout>
