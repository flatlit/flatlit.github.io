---
import { getCollection } from "astro:content";
import JamCardLink from "../../components/JamCardLink.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import Layout from "../../layouts/Page.astro";
import { publishedFilter } from "../../utils";

const games = (await getCollection("jams", publishedFilter)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <h1 class="text-4xl mb-8">Game Jams</h1>
  <section class="grid grid-cols-2 gap-16 justify-items-center">
    {games.map((game) => <JamCardLink {game} />)}
  </section>
</Layout>
