---
import { getCollection } from "astro:content";
import GameCardLink from "../../components/GameCardLink.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import Layout from "../../layouts/Page.astro";
import { publishedFilter, publishedOrder } from "../../utils";

const items = (await getCollection("games", publishedFilter)).sort(
  publishedOrder,
);
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <h1 class="text-4xl mb-8">Games</h1>
  <section class="grid grid-cols-2 gap-16 justify-items-center">
    {items.map((item) => <GameCardLink {item} />)}
  </section>
</Layout>
