---
import { getCollection } from "astro:content";
import BlogCardLink from "../../components/BlogCardLink.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import Layout from "../../layouts/Page.astro";
import { publishedFilter } from "../../utils";

const posts = (await getCollection("blog", publishedFilter)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <h1 class="text-4xl mb-8">Blog</h1>
  <section class="grid grid-cols-2 gap-16 justify-items-center">
    {posts.map((post) => <BlogCardLink post={post} />)}
  </section>
</Layout>
